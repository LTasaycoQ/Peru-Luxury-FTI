---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Fondo from "../../components/Fondo.astro";
const fondoOfi = "https://res.cloudinary.com/dlgeap8h0/image/upload/v1771514450/mapi-portada_vvfhnw.webp";

import DetailPrograms from "../../components/programs/ProgramsDetail/detailPrograms.astro";

import { programs } from "../../data/programs/programs-experiences";

export async function getStaticPaths() {
  return programs.map((dest) => ({
    params: { programsDetail: dest.name },
    props: { ...dest },
  }));
}

const {
  title,
  text,
  programBreve,
  programItenerario,
  programNoIncluye,
  programIncluye,
} = Astro.props;
---

<BaseLayout title={title} description={text} ogImage={fondoOfi}>
  {programItenerario?.[0]?.ite_image?.[0] && (
    <link
      rel="preload"
      as="image"
      href={`${programItenerario[0].ite_image[0].replace('/upload/', '/upload/f_auto,q_auto,w_600/')}`}
      slot="head"
    />
  )}

  <Fondo fondo={`url(${fondoOfi})`} />
  <main>
    <DetailPrograms
      title={title}
      programNoIncluye={programNoIncluye}
      programIncluye={programIncluye}
      programBreve={programBreve}
      programItenerario={programItenerario}
    />
  </main>
</BaseLayout>