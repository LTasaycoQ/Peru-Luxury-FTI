---
import BaseLayout from "../../layouts/BaseLayout.astro";
import DistrictInicio from "../../components/destinations/distritos/districtInicio.astro";
import OurParners from "../../components/destinations/distritos/OurParners.astro";
import ExceptionalExperience from "../../components/destinations/distritos/ExceptionalExperience.astro";
import Fondo from "../../components/Fondo.astro";

import { destinations } from "../../data/destinations/destinatios";
import { hotels } from "../../data/destinations/hotels";
import { destinationsExp } from "../../data/destinations/experienceDestinations";

export async function getStaticPaths() {
  return destinations.map((dest) => ({
    params: { destination: dest.distrito },
    props: { ...dest },
  }));
}

const {
  titleSEO,
  title,
  description,
  image1,
  image2,
  partnersTitle,
  image3,
  fondo,
  execptionalEXperience,
} = Astro.props;

const destinationHotels = hotels.filter(
  (hotel) => hotel.destination === Astro.params.destination
);



const partnersFormatted = destinationHotels.map((hotel) => ({
  image: hotel.fondo,
  name: hotel.title,
  link: `/parners/${hotel.slug}`,
}));



const experienceDestinations = destinationsExp.filter(
  (destinationsExp) => destinationsExp.destination === Astro.params.destination
);


const experienceDestinationsFormatted = experienceDestinations.map((experience) => ({

}));


---

<BaseLayout title={titleSEO} description={description} ogImage={fondo}>
  <Fondo fondo={`url(${fondo})`} />

  <main>
    <DistrictInicio
      title={title}
      description={description}
      image1={image1}
      image2={image2}
      image3={image3}
    />

    <ExceptionalExperience experience={experienceDestinationsFormatted} />

    <OurParners
      title={partnersTitle}
      variant="default"
      partners={partnersFormatted}
    />
  </main>
</BaseLayout>