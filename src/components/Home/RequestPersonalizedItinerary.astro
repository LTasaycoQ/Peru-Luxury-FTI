---
import { Image } from "astro:assets";
import contactImage from "../../assets/image/Home-img/contact-us.webp";
---

<section class="section-form-Itinerary">
  <div class="container__All--itinerary">
    <div class="container-itinerary">
      <h3 data-aos="fade-right" class="title-h2">Your Journey Starts Here</h3>
      <p class="text-parrafo">
        Request Your personalizaed itinerary and start your <br /> unforgettable journey.
      </p>
      <div class="w-full">
        <form action="" class="formulario-itinerary">
          <div class="container-input">
            <input name="Nombre" required placeholder="Full Name" type="text" />
            <input name="Email" required type="email" placeholder="Email" />
          </div>
          <button id="btn-itinerary" class="btn-itenerary" type="submit">Submit</button>
          <div id="turnstile-container"></div>
        </form>
        <p id="form-msg-itenerary">✓ Sent Successfully</p>
        <p id="form-msg-captcha">Fallo al Enviar la Solicitud</p>
      </div>
    </div>
    <div>
      <Image
        class="imagenItineray rounded-[12px]"
        alt="imagen - contact"
        src={contactImage}
      />
    </div>
  </div>
</section>

<script>
  declare global {
    interface Window {
      turnstile?: {
        render: (container: HTMLElement, options?: { sitekey: string }) => void;
        getResponse: () => string | undefined;
        reset: () => void;
      };
    }
  }

  function initItineraryForm() {
    const form = document.querySelector(".formulario-itinerary") as HTMLFormElement;
    const btn = document.getElementById("btn-itinerary") as HTMLButtonElement;
    const msgSuccess = document.getElementById("form-msg-itenerary");
    const msgError = document.getElementById("form-msg-captcha");
    const turnstileContainer = document.getElementById("turnstile-container") as HTMLElement;

    if (!form || !btn || !turnstileContainer) return;

    // Limpiar cualquier render previo de Turnstile
    turnstileContainer.innerHTML = "";

    const renderTurnstile = () => {
      window.turnstile?.render(turnstileContainer, {
        sitekey: "0x4AAAAAADPRDCFRFmqKw5yy",
      });
    };

    if (window.turnstile) {
      renderTurnstile();
    } else {
      window.addEventListener("load", renderTurnstile, { once: true });
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const apiMailEndpoint = "https://fti-emailservice.vercel.app/contact";

      if (msgError) msgError.style.display = "none";
      if (msgSuccess) msgSuccess.style.display = "none";

      const turnstileResponse = window.turnstile?.getResponse();

      if (!turnstileResponse) {
        if (msgError) {
          msgError.innerText = "Please verify the captcha";
          msgError.style.display = "block";
        }
        return;
      }

      btn.disabled = true;
      btn.innerText = "Sending...";

      const formData = new FormData(form);
      const data = {
        nombre: formData.get("Nombre"),
        email: formData.get("Email"),
        captcha: turnstileResponse,
      };

      try {
        const response = await fetch(apiMailEndpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (!response.ok) throw new Error(`Error: ${response.status}`);

        if (msgSuccess) {
          msgSuccess.style.display = "block";
          msgSuccess.style.color = "#D9B244";
          msgSuccess.innerText = "✓ Sent Successfully";
        }

        form.reset();
        window.turnstile?.reset();

      } catch (error) {
        console.error("Error:", error);
        if (msgSuccess) {
          msgSuccess.innerText = "Something went wrong. Please try again.";
          msgSuccess.style.color = "#e57373";
          msgSuccess.style.display = "block";
        }
      } finally {
        btn.disabled = false;
        btn.innerText = "Submit";
      }
    });
  }

  document.addEventListener("astro:page-load", initItineraryForm);
</script>

<style>
  #form-msg-itenerary {
    display: none;
    color: #dabb42;
    font-size: 13px;
    margin-top: 6px;
  }
  #form-msg-captcha {
    display: none;
    color: #883117;
    font-size: 14px;
    font-weight: 700;
    margin-top: 6px;
  }
  .btn-itenerary {
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
    background: linear-gradient(135deg, #cf7b4e, #dabb42);
  }

  .title-h2 {
    margin-bottom: 25px;
    font-size: 37.5px;
  }
  .text-parrafo {
    margin-bottom: 65px;
    font-size: 18.4px;
    color: rgb(13, 29, 63);
    font-weight: 300;
  }

  .section-form-Itinerary {
    padding: 30px;
    margin-top: 12em;
    width: 100%;
    background-color: #f7f7f7;
    font-family: "Poppins";
    display: flex;
    gap: 40px;
    justify-content: center;
    align-items: center;
  }

  .container__All--itinerary {
    width: 110em;
    margin-bottom: 100px;
    margin-top: 50px;
    display: flex;
    gap: 40px;
    justify-content: space-around;
    align-items: center;
  }

  .formulario-itinerary {
    width: 100%;
    display: flex;
    gap: 20px;
  }

  @media (width < 64rem) {
    .container__All--itinerary {
      flex-direction: column;
    }
  }

  .container-input {
    display: flex;
    gap: 20px;
  }

  .formulario-itinerary input {
    padding: 10px;
    width: 50%;
    font-weight: 300;
    color: rgb(100, 100, 100);
    outline: none;
    background-color: white;
    border: 1px solid rgb(201, 201, 201);
  }
  .formulario-itinerary button {
    padding: 10px;
    width: 200px;
    border-radius: 50px;
    font-size: 18px;
    font-weight: 700;
    color: white;
    background-color: #dabb42;
    cursor: pointer;
  }
  .formulario-itinerary button:hover {
    background-color: #f7d30e;
  }
  .imagenItineray {
    width: 42em;
  }

  @media (width < 48rem) {
    .formulario-itinerary button,
    .formulario-itinerary input,
    .formulario-itinerary,
    .container-input {
      width: 100%;
      flex-direction: column;
    }
  }
</style>