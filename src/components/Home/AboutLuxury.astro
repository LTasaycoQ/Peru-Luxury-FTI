---
import { Image } from "astro:assets";
import peopleImg from "../../assets/image/Home-img/plj01.webp"
---

<section class="about-section">
    <div class="about-container">
        <div class="about-content">
            <h1 class="about-title" data-aos="fade-right">
                Crafting Tailor-Made <br>
                <span class="highlight">Luxury Experiences Since 1976</span>
            </h1>
            
            <div class="about-text-wrapper">
                <p class="about-description">
                    Since 1976, <i>Peru Luxury Journeys </i> has been a luxury travel operator specializing in tailor-made journeys that showcase the very best of Peru. With nearly five decades of experience, we combine in-depth destination knowledge with meticulous attention to detail, offering exclusive experiences that exceed the expectations of the most discerning travelers. We design personalized itineraries to the country’s top destinations—from the majesty of Machu Picchu to the vastness of the Amazon—committed to delivering excellence, authenticity, and impeccable service at every stage of the journey.
                </p>
                <a href="/about-us" class="btn-link">About us</a>
            </div>
        </div>

        <div class="about-image-wrapper">
            <Image 
                class="about-image" 
                src={peopleImg} 
                alt="Luxury experience in Peru" 
                loading="lazy"
            />
        </div>
    </div>
</section>

<style>
    .about-section {
        font-family: 'Poppins', sans-serif;
        padding-top: 90px;
        padding-bottom: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .about-container {
        display: flex;
        width: 90%;
        max-width: 100em;
        padding-left: 20px;
        padding-right: 20px;
        justify-content: space-between;
        align-items: center;
        gap: 80px;
    }

    
    .about-content {
        width: 100%;
        max-width: 630px; 
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .about-title {
        font-size: 40px;
        line-height: 1.2;
        margin: 0;
        font-weight: 400;
        color: #1a1a1a;
    }

    .about-title .highlight {
        font-weight: 700;
    }

    .about-text-wrapper {
        display: flex;
        flex-direction: column;
    }

    .about-description {
        color: #4b5563; 
        padding-bottom: 30px;
        font-size: 15px;
        line-height: 1.6;
        margin: 0;
    }

    .about-image-wrapper {
        flex-shrink: 0;
    }

    .about-image {
        width: 27em;
        height: auto;
        border-radius: 20px;
        object-fit: cover;
        display: block;
    }

    .btn-link {
        display: inline-block;
        width: fit-content;
        text-decoration: none;
    }


    @media (min-width: 1536px) {
        .about-image {
            width: 45em;
        }
    }

    @media (max-width: 1280px) {
        .about-title {
            font-size: 35px;
        }
        .about-content {
            max-width: 500px;
        }
    }

    @media (max-width: 1024px) {
        .about-container {
            flex-direction: column-reverse;
            gap: 40px;
            width: 90%;
        }

        .about-content {
            max-width: 100%;
        }

        .about-title {
            font-size: 40px;
        }

        .about-text-wrapper {
            align-items: center;
        }

        .about-description {
            text-align: center;
            font-size: 13px;
        }

        .about-image {
            width: 100%;
        }
    }

    @media (max-width: 768px) {
        .about-section {
            padding-top: 60px;
            padding-bottom: 60px;
        }
        
        .about-title {
            text-align: center;
            font-size: 30px;
        }
        
        .about-container {
            gap: 30px;
        }
    }
</style>