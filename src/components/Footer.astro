---
import { Image } from "astro:assets";
import { destinations } from "../data/destinations/destinatios";
import "../styles/footer.css"
const topDestinations = destinations.slice(0, 9);

import logo from "../assets/logo/PLJ-LOGO-1.webp"
---

<footer class="footer-modern">
  <div class="footer-content">
    
    <div class="footer-brand">
      <Image src={logo} format="png" alt="Logo" class="footer-logo">
      <p class="brand-description">
        Crafting unique and unforgettable luxury experiences across the wonders of Peru.
      </p>
    </div>

    <div class="footer-links-wrapper">
      <div class="link-group">
        <h4>Explore</h4>
        <ul>
          <li><a href="/destinations">Destinations</a> <i class="link-icon bi bi-box-arrow-up-right"></i></li>
          <li><a href="/tour-itineraries">Luxury Programs</a> <i class="link-icon bi bi-box-arrow-up-right"></i></li>
          <li><a href="/about-us">About Our Story</a> <i class="link-icon bi bi-box-arrow-up-right"></i></li>
        </ul>
      </div>
      <div class="link-group">
        <h4>Top Destinations</h4>
        <ul class="destinations-grid">
          {topDestinations.map(d => (
            <li>
              <i class="bi bi-link-45deg"></i>
              <a href={`/destinations/${d.distrito}`}>
                {d.distrito.charAt(0).toUpperCase() + d.distrito.slice(1).replace(/-/g, " ")}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-newsletter">
      <h4>Join Our Newsletter</h4>
      <p>Receive exclusive travel tips and luxury offers.</p>
      <form id="formulario-subcription" class="form-contacto-subcribete">
        <div class="input-box">
          <div class="box-input--form">
            <input class="input-footer" name="Nombre" type="text" required placeholder="First Name">
            <input class="input-footer" name="Apellido" type="text" required placeholder="Last Name">
          </div>
          <input class="input-footer" name="Email" type="email" required placeholder="Email">
          <button id="btn-submit" class="button" type="submit">Subscribe</button>
          <p id="form-msg" style="display:none; color:#DABB42; font-size:13px; margin-top:6px;">✓ You're subscribed!</p>
        </div>
      </form>
    </div>
  </div>
</footer>

<script is:inline>
  const apiMailEndpointSubscribete = "https://organic-florencia-fiesta-tours-f2514923.koyeb.app/subscribe";
  const formSubscribete = document.querySelector(".form-contacto-subcribete");

  formSubscribete?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const btn = formSubscribete.querySelector("button");
    btn.disabled = true;
    btn.innerText = "Sending...";

    const formData = new FormData(formSubscribete);
    const data = {
      nombre: formData.get("Nombre"),
      apellido: formData.get("Apellido"),
      email: formData.get("Email")
    };

    try {
      const response = await fetch(apiMailEndpointSubscribete, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
      });

      if (!response.ok) throw new Error(`Error: ${response.status}`);

      await response.json();

      document.getElementById("form-msg").style.display = "block";
      formSubscribete.reset();

    } catch (error) {
      console.error("Error:", error);
      document.getElementById("form-msg").innerText = "Something went wrong. Please try again.";
      document.getElementById("form-msg").style.color = "#e57373";
      document.getElementById("form-msg").style.display = "block";
    } finally {
      btn.disabled = false;
      btn.innerText = "Subscribe";
    }
  });
</script>

<style>
.footer-modern {
  background-color: #111111;
  color: #e5e5e5;
  padding: 3rem 1rem;
}

.footer-content {
  max-width: 1280px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  gap: 2rem;
}

.footer-brand {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  flex-direction: column;
}

.footer-logo {
  filter: brightness(15);
  width: 100%;
  max-width: 320px;
  margin-bottom: 1rem;
}

.brand-description {
  font-size: 0.875rem;
  line-height: 1.5;
  color: #9ca3af;
  max-width: 280px;
}

.footer-links-wrapper {
  display: flex;
  gap: 80px;
}

/* Link Groups */
.link-group h4 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 1rem;
  color: white;
}

.link-group ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.link-group li {
  margin-bottom: 0.5rem;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.link-group a {
  color: #9ca3af;
  text-decoration: none;
  transition: color 0.3s ease;
}

.link-group a:hover {
  color: #DABB42;
}

.link-icon {
  padding-left: 10px;
  font-size: 14px;
  color: #9ca3af;
}
.destinations-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  justify-content: center;
  width: 100%;
  gap: 0.5rem 1rem;
}

.destinations-grid li {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.destinations-grid i {
  font-size: 0.75rem;
  color: #DABB42;
}

.destinations-grid a {
  font-size: 0.875rem;
}

/* Newsletter Section */
.footer-newsletter {
  flex: 1;
  max-width: 300px;
}

.footer-newsletter h4 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: white;
}

.footer-newsletter p {
  font-size: 0.875rem;
  color: #9ca3af;
  margin-bottom: 1rem;
}

.form-contacto-subcribete {
  width: 100%;
}

.input-box {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.box-input--form {
  display: flex;
  gap: 0.75rem;
}

.box-input--form .input-footer {
  flex: 1;
}

.input-footer {
  width: 100%;
  padding: 0.75rem;
  background-color: #ffffff;
  border: 1px solid #374151;
  border-radius: 0.375rem;
  color: white;
  font-size: 0.875rem;
  transition: border-color 0.3s ease;
}

.input-footer:focus {
  outline: none;
  border-color: #DABB42;
}

.input-footer::placeholder {
  color: #6b7280;
}

.button {
  width: 100%;
  padding: 0.75rem;
  background-color: #DABB42;
  color: #111111;
  font-weight: 600;
  border: none;
  border-radius: 0.375rem;
  cursor: pointer;
  transition: all 0.3s ease;
}

.button:hover {
  background-color: #c4a635;
  transform: translateY(-1px);
}

.button:disabled {
  opacity: 0.7;
  cursor: not-allowed;
  transform: none;
}

@media (max-width: 1024px) {
  .footer-content {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
  }

  .footer-brand {
    align-items: center;
    text-align: center;
  }

  .brand-description {
    max-width: 100%;
  }

  .footer-links-wrapper {
    flex-direction: column;
    gap: 2rem;
    width: 100%;
    align-items: center;
  }

  .link-group {
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
  }

  .link-group h4 {
    text-align: center;
  }

  .link-group ul {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .destinations-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem 1.5rem;
  }

  .footer-newsletter {
    max-width: 100%;
    width: 100%;
    text-align: center;
  }

  .footer-newsletter h4,
  .footer-newsletter p {
    text-align: center;
  }
}

@media (max-width: 640px) {
  .footer-modern {
    padding: 2rem 1rem;
  }

  .footer-logo {
    max-width: 200px;
    display: grid;
    grid-auto-flow: column;
    justify-items: center;
    align-items: center;
  }

  .brand-description {
    text-align: center;
  }

  .footer-links-wrapper {
    gap: 1.5rem;
  }

  .link-group h4 {
    text-align: center;
  }

  .destinations-grid {
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }

  .destinations-grid li {
    justify-content: center;
  }

  .box-input--form {
    flex-direction: column;
    gap: 0.75rem;
  }

  .input-footer {
    padding: 0.625rem;
  }

  .button {
    padding: 0.625rem;
  }

  .link-icon {
    display: none;
  }
}

@media (max-width: 768px) {
  .footer-logo {
    width: 320px;
    padding-bottom: 10px;
  }

  .link-group h4 {
    text-align: center;
  }
}
</style>