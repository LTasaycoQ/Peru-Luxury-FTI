---
interface ImageItem {
  image: string;
}

interface Props {
  texto: string;
  title: string;
  rightImage: ImageItem[];
  downImage: ImageItem[];
}

const { texto, title, rightImage, downImage } = Astro.props;

function cloudinaryOptimize(url: string, width: number): string {
  if (!url.includes('res.cloudinary.com')) return url;
  return url.replace('/upload/', `/upload/f_auto,q_auto,w_${width}/`);
}
---

<section class="font-[Poppins] py-[70px] pb-[110px] flex flex-col items-center w-full bg-white">
    <div class="w-[90%] max-w-[1000px] flex flex-col">
        
        <h1 class="text-[28px] md:text-[36px] font-semibold mb-[40px] text-center text-black">
            {title}
        </h1>

        <div class="flex pt-[50px] flex-col lg:flex-row gap-[90px] w-full mb-[30px] items-center">
            <div class="flex-1">
                <div 
                    class="text-gray-700 text-[15px] leading-relaxed text-center lg:text-left" 
                    set:html={texto} />
            </div>
            
            <div class="w-full lg:w-[250px] flex lg:flex-col max-md:flex-col flex-wrap gap-[15px]">
                {rightImage.map((items: ImageItem, index: number) => (
                    <img 
                        src={cloudinaryOptimize(items.image, 700)}
                        width="250" 
                        height="160"
                        loading={index === 0 ? "eager" : "lazy"}
                        fetchpriority={index === 0 ? "high" : "auto"}
                        decoding="async"
                        class="w-full lg:h-[160px] h-[270px] object-cover rounded-[4px] block shadow-sm img-placeholder" 
                        alt={`${title} - imagen ${index + 1}`}
                    />
                ))}
            </div>
        </div>

        <div class="flex pt-[40px] flex-col md:flex-row justify-between gap-[15px] w-full">
            {downImage.map((items: ImageItem, index: number) => (
                <div class="flex-1 md:max-w-[290px] max-md:w-[100%]">
                    <img 
                        src={cloudinaryOptimize(items.image, 700)}
                        width="290" 
                        height="160"
                        loading="lazy"
                        decoding="async"
                        class="w-full h-[160px] object-cover rounded-[4px] block shadow-sm img-placeholder" 
                        alt={`${title} - imagen ${index + 1}`}
                    />
                </div>
            ))}
        </div>
    </div>
</section>