---
interface ImageItem {
  image: string;
}

interface Props {
  texto: string;
  title: string;
  rightImage: ImageItem[];
  downImage: ImageItem[];
}

const { texto, title, rightImage, downImage } = Astro.props;

function cloudinaryOptimize(url: string, width: number): string {
  if (!url.includes('res.cloudinary.com')) return url;
  return url.replace('/upload/', `/upload/f_auto,q_auto,w_${width}/`);
}
---


<section class="section-container">
  <div class="content-wrapper">
    
    <h1 class="title">
      {title}
    </h1>

    <div class="main-row">
      <div class="text-content">
        <div set:html={texto} />
      </div>
      
      <div class="right-images">
        {rightImage.map((items: ImageItem, index: number) => (
          <img 
            src={cloudinaryOptimize(items.image, 700)}
            width="250" 
            height="160"
            loading={index === 0 ? "eager" : "lazy"}
            fetchpriority={index === 0 ? "high" : "auto"}
            decoding="async"
            class="right-image"
            alt={`${title} - imagen ${index + 1}`}
          />
        ))}
      </div>
    </div>

    <div class="down-images">
      {downImage.map((items: ImageItem, index: number) => (
        <div class="down-image-wrapper">
          <img 
            src={cloudinaryOptimize(items.image, 700)}
            width="290" 
            height="160"
            loading="lazy"
            decoding="async"
            class="down-image"
            alt={`${title} - imagen ${index + 1}`}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-container {
    font-family: 'Poppins', sans-serif;
    padding-top: 70px;
    padding-bottom: 110px;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    background-color: white;
  }

  .content-wrapper {
    width: 90%;
    max-width: 1000px;
    display: flex;
    flex-direction: column;
  }

  .title {
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 40px;
    text-align: center;
    color: black;
  }

  .main-row {
    display: flex;
    padding-top: 50px;
    gap: 90px;
    width: 100%;
    margin-bottom: 30px;
    align-items: center;
  }

  .text-content {
    flex: 1;
  }

  .text-content :deep(p) {
    color: #374151;
    font-size: 15px;
    line-height: 1.625;
    text-align: center;
  }

  .right-images {
    width: 250px;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .right-image {
    width: 100%;
    height: 270px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
  }

  .down-images {
    display: flex;
    padding-top: 40px;
    flex-direction: column;
    justify-content: space-between;
    gap: 15px;
    width: 100%;
  }

  .down-image-wrapper {
    flex: 1;
    width: 100%;
  }

  .down-image {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
  }

  @media (width > 768px) {
    .title {
      font-size: 36px;
    }

    .text-content :deep(p) {
      text-align: left;
    }

    .right-images {
      width: 290px;
      flex-direction: column;
    }

    .right-image {
      width: 100%;
      height: 160px;
    }

    .down-images {
      flex-direction: row;
    }

    .down-image-wrapper {
      max-width: 290px;
    }
  }

  @media (max-width: 1024px) {
       .right-images {
      width: 100%;
    }
    .main-row {
      flex-direction: column;
    }
  }

  .img-placeholder {
    background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: loading 1.5s infinite;
  }

  @keyframes loading {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  img {
    background-color: #f3f4f6;
  }
</style>
