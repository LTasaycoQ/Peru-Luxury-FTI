---
interface programItenerario {
    ite_titulo: string;
    ite_text: string;
    ite_image: string[];
}
interface programIncluye {
    text: string;
}
interface programNoIncluye {
    text: string;
}
interface programBreve {
    titulo_breve: string;
    text_breve: string;
}
interface Props {
    title: string;
    programBreve: programBreve[];
    programItenerario: programItenerario[];
    programIncluye: programIncluye[];
    programNoIncluye: programNoIncluye[];    
}

const { title, programBreve, programItenerario, programNoIncluye, programIncluye } = Astro.props;
---

<section class="font-[Poppins] bg-[#FAFAF8] w-full flex flex-col justify-center items-center p-[30px]">
    <div class="w-[80%] max-lg:w-full pt-[30px]">
        <h1 data-aos="fade-up" class="text-start text-[36px] text-gray-800 font-medium">
            {title}
        </h1>

        <br><br>
        
        <div class="w-full">
            <div class="flex flex-col pb-[20px] text-center items-start">
                <ul id="tab-menu" class="w-[50%] max-md:w-full border-[1px] border-gray-200 flex justify-between text-gray-500 font-normal text-center rounded-[10px] overflow-hidden">
                    <li class="menu-list active w-1/3" data-target="brief">Brief</li>
                    <li class="menu-list w-1/3" data-target="itinerary">Itinerary</li>
                    <li class="menu-list w-1/3" data-target="include">Include</li>
                </ul>
            </div>

            <div class="p-[20px] max-md:p-[0]">
                <div id="brief" class="tab-content">
                    {programBreve.map((breve) => (
                        <div class="py-[16px] pb-[10px]">
                            <h3 class="flex gap-[10px] text-gray-700 text-[20px] font-[500]">{breve.titulo_breve}</h3>
                            <span class="text-gray-700 text-[15px] font-[300]">{breve.text_breve}</span>
                        </div>
                    ))}
                </div>

                <div id="itinerary" class="tab-content hidden">
                    {programItenerario.map((itenerario, index) => (
                        <div class="py-[8px] accordion-item">
                            <button class="accordion-header bg-[#FAFAFF] max-md:text-[18px] text-[20px] font-[500] p-[13px] rounded-t-[10px] text-gray-700 border-[1px] border-gray-200 flex justify-between items-center w-full text-left" data-index={index}>
                                {itenerario.ite_titulo}
                                <svg class="chevron transition-transform duration-500" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                            </button>

                            <div class="accordion-body" style={index === 0 ? "grid-template-rows: 1fr;" : "grid-template-rows: 0fr;"}>
                                <div class="overflow-hidden">
                                    <div class="flex flex-row max-lg:flex-col gap-[30px] p-[30px] border-[1px] border-gray-200 border-t-0 bg-[#FAFAFF] rounded-b-[10px]">
                                        <div class="w-[60%] max-lg:w-full">
                                            <p class="text-[15px] font-[300] text-gray-700 leading-relaxed" set:html={itenerario.ite_text}></p>
                                        </div>
                                        
                                        <div class="img-gallery w-[40%] max-lg:w-full">
                                            {itenerario.ite_image.map((img) => (
                                                <img class="gallery-img" src={img} alt={itenerario.ite_titulo} />
                                            ))}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>

                <div id="include" class="tab-content hidden flex justify-center gap-[60px] max-md:flex-col">
                    <div class="flex-1">
                        <div class="p-[20px] shadow-2xl shadow-gray-300 rounded-[10px] bg-[#FAFAFF] h-full border border-gray-100">
                            <h4 class="font-semibold mb-4 text-green-700">Includes:</h4>
                            {programIncluye.map((item) => (
                                <ul class="flex flex-col">
                                    <li class="text-[14px] text-gray-700 pb-[8px] flex gap-[13.5px]">
                                        <i class="text-[15px] text-green-600 bi bi-patch-check"></i> {item.text}
                                    </li>
                                </ul>
                            ))}
                        </div>
                    </div>
                    <div class="flex-1">
                        <div class="p-[20px] shadow-2xl shadow-gray-300 rounded-[10px] bg-[#FAFAFF] h-full border border-gray-100">
                             <h4 class="font-semibold mb-4 text-red-700">Does not include:</h4>
                            {programNoIncluye.map((item) => (
                                <ul class="flex flex-col">
                                    <li class="text-[14px] pb-[8px] text-gray-700 flex gap-[13.5px]">
                                        <i class="text-red-400 bi bi-x-circle"></i> {item.text}
                                    </li>
                                </ul>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // --- LÓGICA DE TABS ---
    const tabs = document.querySelectorAll('.menu-list');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            const target = tab.getAttribute('data-target');
            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            contents.forEach(content => {
                content.classList.toggle('hidden', content.id !== target);
                if(target === 'include' && content.id === 'include') content.classList.add('flex');
            });
        });
    });

    // --- LÓGICA DE ACORDEÓN (JS) ---
    const headers = document.querySelectorAll('.accordion-header');

    headers.forEach(header => {
        header.addEventListener('click', () => {
            const body = header.nextElementSibling as HTMLElement;
            const chevron = header.querySelector('.chevron');
            const isOpen = body.style.gridTemplateRows === "1fr";

            // Cerrar todos los demás
            document.querySelectorAll('.accordion-body').forEach((b: any) => {
                b.style.gridTemplateRows = "0fr";
            });
            document.querySelectorAll('.chevron').forEach((c: any) => {
                c.style.transform = "rotate(0deg)";
            });

            // Si no estaba abierto, abrirlo
            if (!isOpen) {
                body.style.gridTemplateRows = "1fr";
                if (chevron) (chevron as HTMLElement).style.transform = "rotate(-180deg)";
            }
        });
    });

    // Inicializar el primero abierto (opcional, si el CSS inline no bastara)
    const firstChevron = document.querySelector('.accordion-item:first-child .chevron');
    if (firstChevron) (firstChevron as HTMLElement).style.transform = "rotate(-180deg)";
</script>

<style>
/* --- ANIMACIÓN CSS --- */
.accordion-body {
    display: grid;
    transition: grid-template-rows 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.accordion-header {
    cursor: pointer;
    transition: background-color 0.3s ease;
    outline: none;
}

.accordion-header:hover {
    background-color: #f0f0ff;
}

/* --- GALERÍA VERTICAL DESKTOP --- */
.img-gallery {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    gap: 20px;
}

.gallery-img {
    width: 300px !important;
    height: auto !important;
    border-radius: 10px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

/* --- RESPONSIVE --- */
@media (max-width: 1024px) {
    .img-gallery {
        flex-direction: row !important;
        flex-wrap: wrap !important;
        justify-content: center !important;
    }
    .gallery-img { width: 45% !important; }
}

@media (max-width: 640px) {
    .gallery-img { width: 100% !important; }
}

/* --- ESTILOS GENERALES --- */
.active {
    color: white;
    background-color: #d4c06d;
    font-weight: 600;
}

.menu-list {
    padding: 13px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.menu-list:hover:not(.active) {
    background-color: #f3f4f6;
    color: #d4c06d;
}
</style>