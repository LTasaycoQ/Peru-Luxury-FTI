---
import { programs } from "../../data/programs/programs-experiences";

const ruta = "tour-itineraries";
---

<section class="font-[Poppins]">
    <div class="container-Experiences">
        <div class="container-title">
            <h1 class="title">
                Exclusive Experiences to <br />
                Discover the Best of Peru.
            </h1>
            <div class="line max-sm:hidden"></div>
        </div>

        <p class="text-parrafo">
            At Peru Luxury Journeys, we craft unique itineraries for travelers
            striving for greatness. <br />
            Each tour combines iconic destinations, meticulously planned details,
            and authentic experiences. <br />
            Let our experts guide you on an unforgettable journey.
        </p>

        <div class="cards-grid">
            {
                programs.map((items) => {
                    const urlFinal =
                        items.name === "seven"
                            ? `/${items.name}`
                            : `/${ruta}/${items.name}`;
                    return (
                        <a href={urlFinal} class="card-link">
                            <div class="card" data-aos="flip-left">
                                <div class="image-container">
                                    <img
                                        src={items.fondo}
                                        alt={items.title}
                                        class="card-image"
                                    />
                                </div>
                                <div class="card-content">
                                    <h3 class="card-title">{items.title}</h3>
                                    <p class="card-text pb-[20px]">
                                        {items.text}
                                    </p>
                                    <i class="link-read-more">Read More</i>
                                </div>
                            </div>
                        </a>
                    );
                })
            }
        </div>
    </div>
</section>

<style>
    .image-container:hover .card-image {
        transition: all 2s;
        -webkit-transform: scale(1.3);
        transform: scale(1.3);
    }
    .image-container {
        overflow: hidden;
    }

    .container-Experiences {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem;
    }

    .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        width: 100%;
        max-width: 1200px;
        margin-top: 50px;
    }

    .card {
        overflow: hidden;
        transition: transform 0.3s ease;
    }

    .card-image {
        width: 100%;
        height: 400px;
        object-fit: cover;
    }

    .card-content {
        padding: 20px 0px;
    }

    .card-title {
        display: block;
        font-size: 1.4rem;
        font-weight: 600;
        color: #212121;
        margin-bottom: 10px;
    }
    .card-text {
        color: rgb(54, 54, 54);
        font-weight: 300;
    }

    .text-parrafo {
        margin-top: 15px;
        margin-bottom: 40px;
        text-align: center;
        color: #4e4e4e;
        font-weight: 300;
    }
    .container-title {
        width: 100%;
        margin-top: 30px;
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 30px;
    }
    .title {
        text-align: center;
        font-size: 28px;
    }
    .line {
        width: 280px;
        border-top: 2px solid #c5a822;
    }
</style>
