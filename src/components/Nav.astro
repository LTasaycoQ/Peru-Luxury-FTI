---
import { destinations } from "../data/destinations/destinatios";
import HeaderTop from "./HeaderTop.astro";
import { Image } from "astro:assets";
import logo from "../assets/logo/PLJ-LOGO-1.webp";
---

<header class="header">
    <HeaderTop />
    <div class="nav-container">
        <nav class="nav">
            <div class="nav-wrapper">
                <a href="/" class="logo-link">
                    <Image format="png" src={logo} loading="eager" class="logo" alt="logo-peru-luxy" />
                </a>

                <button
                    id="btnMenu"
                    aria-label="Abrir menú"
                    aria-expanded="false"
                    class="menu-button">
                    <i id="openMenu" class="bi bi-list menu-icon-open"></i>
                    <i id="closeMenu" class="bi bi-x-lg menu-icon-close hidden"></i>
                </button>

                <ul class="nav-links">
                    <li class="nav-item">
                        <button id="btnSubmenuDesktop" class="nav-button">
                            <i id="iconSubmenu" class="bi bi-caret-right-fill submenu-icon"></i>
                            <a href="/destinations">DESTINATIONS</a>
                        </button>
                        <div id="submenu" class="submenu hidden">
                            <ul class="submenu-list">
                                {destinations.map(d => (
                                    <li class="submenu-item">
                                        <a class="submenu-link" href={`/destinations/${d.distrito}`}>
                                            {d.distrito.toUpperCase().replace(/-/g, " ")}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </li>
                    <li class="nav-item"><a href="/tour-itineraries">TOUR ITINERARIES</a></li>
                    <li class="nav-item"><a href="/about-us">ABOUT US</a></li>
                </ul>
            </div>
        </nav>
    </div>

    <div class="mobile-menu">
        <div id="menuResponsive" class="mobile-menu-content hidden">
            <div class="mobile-menu-item">
                <a class="mobile-menu-link" href="/destinations">DESTINATIONS</a>
                <button
                    id="btnSubMenuResponsive"
                    aria-label="Ver destinos"
                    aria-expanded="false"
                    class="mobile-submenu-button">
                    <i id="iconSubMenuResponsiveIcon" class="bi bi-caret-down-fill"></i>
                </button>
            </div>

            <div id="submenuResponsive" class="mobile-submenu hidden">
                <ul class="mobile-submenu-list">
                    {destinations.map(d => (
                        <li>
                            <a class="mobile-submenu-link" href={`/destinations/${d.distrito}`}>
                                {d.distrito.charAt(0).toUpperCase() + d.distrito.slice(1).replace(/-/g, " ")}
                            </a>
                        </li>
                    ))}
                </ul>
            </div>

            <div class="mobile-menu-item">
                <a class="mobile-menu-link" href="/tour-itineraries">TOUR ITINERARIES</a>
            </div>
            <div class="mobile-menu-item">
                <a class="mobile-menu-link" href="/about-us">ABOUT US</a>
            </div>
            <div class="mobile-menu-item">
                <a class="mobile-menu-link whatsapp-link" href="https://api.whatsapp.com/send?phone=51982836947" target="_blank">
                    <i class="bi bi-whatsapp"></i> +51 982 836 947
                </a>
            </div>
            <div class="mobile-menu-item">
                <a class="mobile-menu-link email-link" href="mailto:sales@PeruLuxuryJourneys.com" target="_blank">
                    <i class="bi bi-envelope"></i>sales@PeruLuxuryJourneys.com
                </a>
            </div>
        </div>
    </div>
</header>

<script is:inline>
  function initNav() {
    const btnMenu = document.getElementById("btnMenu");
    const openMenuIcon = document.getElementById("openMenu");
    const closeMenuIcon = document.getElementById("closeMenu");
    const menuResponsive = document.getElementById("menuResponsive");

    btnMenu?.addEventListener("click", () => {
      const isHidden = menuResponsive.classList.contains("hidden");
      menuResponsive.classList.toggle("hidden");
      openMenuIcon.classList.toggle("hidden", isHidden);
      closeMenuIcon.classList.toggle("hidden", !isHidden);
      btnMenu.setAttribute("aria-expanded", String(isHidden));
    });

    const btnSubmenuDesktop = document.getElementById("btnSubmenuDesktop");
    const submenuDesktop = document.getElementById("submenu");
    const iconSubmenu = document.getElementById("iconSubmenu");

    btnSubmenuDesktop?.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = !submenuDesktop.classList.contains("hidden");
      submenuDesktop.classList.toggle("hidden");
      iconSubmenu.style.transform = isOpen ? "rotate(0deg)" : "rotate(90deg)";
      btnSubmenuDesktop.setAttribute("aria-expanded", String(!isOpen));
    });

    document.addEventListener("click", (e) => {
      if (!btnSubmenuDesktop?.contains(e.target)) {
        submenuDesktop?.classList.add("hidden");
        if (iconSubmenu) iconSubmenu.style.transform = "rotate(0deg)";
        btnSubmenuDesktop?.setAttribute("aria-expanded", "false");
      }
    });

    const btnSubMenuResponsive = document.getElementById("btnSubMenuResponsive");
    const submenuResponsive = document.getElementById("submenuResponsive");
    const iconSubMenuResponsiveIcon = document.getElementById("iconSubMenuResponsiveIcon");

    btnSubMenuResponsive?.addEventListener("click", () => {
      const isOpen = !submenuResponsive.classList.contains("hidden");
      submenuResponsive.classList.toggle("hidden");
      iconSubMenuResponsiveIcon.style.transform = isOpen ? "rotate(0deg)" : "rotate(180deg)";
      btnSubMenuResponsive.setAttribute("aria-expanded", String(!isOpen));
    });
  }

  document.addEventListener("astro:page-load", initNav);
</script>

<style>
  /* Reset y estilos base */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* Header principal */
  .header {
    background-color: white;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  /* Contenedor de navegación */
  .nav-container {
    width: 100%;
    background-color: white;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .nav {
    background-color: white;
    width: 70%;
    padding: 5px;
  }

  @media (max-width: 1280px) {
    .nav {
      width: 90%;
    }
  }

  .nav-wrapper {
    display: flex;
    width: 100%;
    justify-content: space-between;
    align-items: center;
  }

  /* Logo */
  .logo-link {
    display: inline-block;
  }

  .logo {
    width: 220px;
  }

  @media (max-width: 640px) {
    .logo {
      width: 210px;
      padding: 7px;
    }
  }

  /* Botón menú móvil */
  .menu-button {
    display: none;
    border-radius: 10px;
    padding: 14px;
    width: 48px;
    height: 48px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #E6E6E6;
    cursor: pointer;
    border: none;
  }

  .menu-icon-open,
  .menu-icon-close {
    font-size: 22px;
  }

  /* Navegación desktop */
  .nav-links {
    width: 40%;
    display: flex;
    align-items: center;
    justify-content: space-around;
    list-style: none;
  }

  .nav-item {
    position: relative;
  }

  .nav-item > a {
    font-size: 14px;
    letter-spacing: 0.05em;
    transition: color 0.3s;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .nav-item > a::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background-color: currentColor;
    transition: width 0.3s ease;
  }

  .nav-item > a:hover::after {
    width: 100%;
  }

  .nav-button {
    display: flex;
    align-items: center;
    gap: 5px;
    background-color: transparent;
    border: none;
    cursor: pointer;
    font-size: 14px;
    letter-spacing: 0.05em;
    transition: color 0.3s;
    position: relative;
  }

  .nav-button a {
    text-decoration: none;
    color: inherit;
  }

  .submenu-icon {
    transition: transform 0.35s ease;
  }

  /* Submenú desktop */
  .submenu {
    position: absolute;
    top: 58px;
    left: -35px;
    z-index: 50;
    background-color: #393939;
    width: 225px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
  }

  .submenu-list {
    list-style: none;
    font-size: 14px;
    color: white;
    width: 100%;
  }

  .submenu-item {
    display: flex;
  }

  .submenu-link {
    padding: 15px;
    width: 100%;
    text-decoration: none;
    color: white;
    transition: background-color 0.25s;
  }

  .submenu-link:hover {
    background-color: #515050;
  }

  /* Menú móvil */
  .mobile-menu {
    display: none;
    width: 100%;
  }

  .mobile-menu-content {
    width: 100%;
    background-color: #393939;
    color: white;
    z-index: 40;
    position: absolute;
    transform-origin: top center;
    animation: animation-desliz 0.5s ease-in-out;
  }

  .mobile-menu-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #555;
  }

  .mobile-menu-link {
    padding: 14px;
    flex: 1;
    font-size: 14px;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: white;
    display: block;
  }

  .whatsapp-link i,
  .email-link i {
    color: #D9B244;
    margin-right: 10px;
  }

  .whatsapp-link,
  .email-link {
    display: flex;
    gap: 10px;
  }

  .mobile-submenu-button {
    padding: 14px;
    background-color: transparent;
    border: none;
    cursor: pointer;
    color: white;
  }

  .mobile-submenu-button i {
    font-size: 14px;
    transition: transform 0.35s ease;
  }

  .mobile-submenu {
    background-color: #2e2e2e;
    transform-origin: top center;
    animation: animation-desliz 0.5s ease-in-out;
  }

  .mobile-submenu-list {
    list-style: none;
    font-size: 13px;
    padding: 8px 0;
  }

  .mobile-submenu-link {
    display: flex;
    padding: 12px 12px 12px 24px;
    text-decoration: none;
    color: white;
    transition: background-color 0.25s;
  }

  .mobile-submenu-link:hover {
    background-color: #515050;
  }

  /* Utilidades */
  .hidden {
    display: none;
  }

  /* Animaciones */
  @keyframes animation-desliz {
    to {
      transform: scaleY(1);
    }
    from {
      transform: scaleY(0);
    }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .nav-links {
      display: none;
    }

    .menu-button {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }

    .nav-links {
      width: auto;
    }
  }
</style>