---
import { destinations } from "../data/destinations/destinatios";
import HeaderTop from "./HeaderTop.astro";
import { Image } from "astro:assets";
import logo from "../assets/logo/PLJ-LOGO-1.webp";
---

<header class="main-header bg-white">
    <HeaderTop />
    
    <input type="checkbox" id="menu-toggle" class="css-toggle-input main-menu-checkbox" />

    <div class="w-full bg-white flex justify-center items-center">
        <nav class="navbar">
            <div class="navbar-container">
                <a href="/">
                    <Image src={logo} format="png" loading="eager" class="logo-image" alt="logo-peru-luxy" />
                </a>

                <label for="menu-toggle" class="menu-toggle" aria-label="Abrir menú">
                    <i class="bi bi-list icon-open"></i>
                    <i class="bi bi-x-lg icon-close"></i>
                </label>

                <ul class="nav-links">
                    <li class="dropdown group-desktop">
                        <input type="checkbox" id="desktop-submenu-toggle" class="css-toggle-input desktop-checkbox" />
                        
                        <label for="desktop-submenu-toggle" class="submenu-trigger">
                            <i id="iconSubmenu" class="bi bi-caret-right-fill"></i>
                            <span class="nav-text-desktop">DESTINATIONS</span>
                        </label>
                        
                        <div class="dropdown-content">
                            <ul>
                                {destinations.map(d => (
                                    <li>
                                        <a href={`/destinations/${d.distrito}`}>
                                            {d.distrito.toUpperCase().replace(/-/g, " ")}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </li>
                    <li class="nav-item"><a href="/tour-itineraries">TOUR ITINERARIES</a></li>
                    <li class="nav-item"><a href="/about-us">ABOUT US</a></li>
                </ul>
            </div>
        </nav>
    </div>

    <div class="mobile-menu-wrapper">
        <div class="mobile-menu">

            <div class="mobile-item-group">
                <a href="/destinations">DESTINATIONS</a>
                
                <input type="checkbox" id="responsive-submenu-toggle" class="css-toggle-input mobile-submenu-checkbox" />
                
                <label for="responsive-submenu-toggle" id="btnSubMenuResponsive">
                    <i id="iconSubMenuResponsiveIcon" class="bi bi-caret-down-fill"></i>
                </label>
                
                <div class="mobile-submenu">
                    <ul>
                        {destinations.map(d => (
                            <li>
                                <a href={`/destinations/${d.distrito}`}>
                                    {d.distrito.charAt(0).toUpperCase() + d.distrito.slice(1).replace(/-/g, " ")}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>

            <div class="mobile-item">
                <a href="/tour-itineraries">TOUR ITINERARIES</a>
            </div>
            <div class="mobile-item">
                <a href="/about-us">ABOUT US</a>
            </div>
            <div class="mobile-item">
                <a href="https://api.whatsapp.com/send?phone=51982836947" target="_blank">
                    <i class="whatsapp-icon bi bi-whatsapp"></i> +51 982 836 947
                </a>
            </div>
            <div class="mobile-item border-none">
                <a href="mailto:sales@PeruLuxuryJourneys.com" target="_blank">
                    <i class="envelope-icon bi bi-envelope"></i> sales@PeruLuxuryJourneys.com
                </a>
            </div>

        </div>
    </div>
</header>

<style>
    :root {
        --dark-bg: #393939;
        --darker-bg: #2e2e2e;
        --hover-bg: #515050;
        --light-gray: #E6E6E6;
        --border-color: #555555;
        --white: #ffffff;
        --accent-gold: #D9B244;
    }

    .css-toggle-input {
        display: none !important;
    }

    .main-header {
        width: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        position: relative;
    }

    .navbar {
        width: 70%;
        padding: 5px;
    }

    .navbar-container {
        display: flex;
        width: 100%;
        justify-content: space-between;
        align-items: center;
    }

    .logo-image {
        width: 220px;
        height: auto;
        display: block;
    }

    .nav-links {
        width: 40%;
        display: flex;
        align-items: center;
        justify-content: space-around;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .nav-item a, .submenu-trigger {
        text-decoration: none;
        color: inherit;
        font-size: 14px;
        letter-spacing: 0.05em;
        position: relative;
        background: transparent;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 4px 0;
    }

    .nav-text-desktop {
        font-size: 14px;
        letter-spacing: 0.05em;
    }

    .nav-item a::after, .submenu-trigger::after {
        content: "";
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1.5px;
        background-color: currentColor;
        transition: width 0.3s ease;
    }

    .nav-item a:hover::after, .submenu-trigger:hover::after {
        width: 100%;
    }

    .dropdown {
        position: relative;
    }

    .dropdown-content {
        display: none;
        position: absolute;
        top: 45px;
        left: -35px;
        z-index: 100;
        background-color: var(--dark-bg);
        width: 225px;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
    }

    .dropdown-content ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .dropdown-content a {
        display: block;
        padding: 15px;
        color: var(--white);
        font-size: 14px;
        text-decoration: none;
        transition: background-color 0.25s;
    }

    .dropdown-content a:hover {
        background-color: var(--hover-bg);
    }

    .menu-toggle {
        display: none;
        border-radius: 10px;
        width: 48px;
        height: 48px;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background-color: var(--light-gray);
        cursor: pointer;
        border: none;
    }

    .menu-toggle i {
        font-size: 22px;
        color: #333;
    }

    .menu-toggle .icon-close {
        display: none;
    }

    .mobile-menu-wrapper {
        display: none;
        width: 100%;
        position: absolute;
        top: 100%;
        left: 0;
        z-index: 40;
    }

    .mobile-menu {
        width: 100%;
        background-color: var(--dark-bg);
        color: var(--white);
    }

    .mobile-item-group, .mobile-item {
        position: relative;
        border-bottom: 1px solid var(--border-color);
        padding: 14px;
    }
    
    .mobile-item-group {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
    }
    
    .mobile-item {
        display: block;
    }

    .mobile-item-group a, .mobile-item a {
        text-decoration: none;
        color: var(--white);
        font-size: 14px;
        letter-spacing: 0.1em;
    }

    #btnSubMenuResponsive {
        background: transparent;
        border: none;
        color: var(--white);
        cursor: pointer;
        padding: 4px 10px;
        display: flex;
        align-items: center;
    }

    .mobile-submenu {
        display: none;
        width: 100%;
        background-color: var(--darker-bg);
        margin-top: 14px;
        margin-left: -14px;
        margin-right: -14px;
    }

    .mobile-submenu ul {
        list-style: none;
        padding: 8px 0;
        margin: 0;
    }

    .mobile-submenu a {
        display: flex;
        padding: 12px 12px 12px 34px;
        text-decoration: none;
        color: var(--white);
        font-size: 13px;
        transition: background-color 0.25s;
    }

    .mobile-submenu a:hover {
        background-color: var(--hover-bg);
    }

    .whatsapp-icon, .envelope-icon {
        color: var(--accent-gold);
        margin-right: 10px;
    }

    .border-none {
        border-bottom: none !important;
    }

    #iconSubmenu, #iconSubMenuResponsiveIcon {
        transition: transform 0.3s ease;
    }

  
    .main-menu-checkbox:checked ~ .w-full .menu-toggle .icon-open {
        display: none !important;
    }
    .main-menu-checkbox:checked ~ .w-full .menu-toggle .icon-close {
        display: block !important;
    }
    .main-menu-checkbox:checked ~ .mobile-menu-wrapper {
        display: block !important;
    }

    .desktop-checkbox:checked ~ .dropdown-content {
        display: block !important;
    }
    .desktop-checkbox:checked ~ .submenu-trigger #iconSubmenu {
        transform: rotate(90deg);
    }

    .mobile-submenu-checkbox:checked ~ .mobile-submenu {
        display: block !important;
    }
    .mobile-submenu-checkbox:checked ~ #btnSubMenuResponsive #iconSubMenuResponsiveIcon {
        transform: rotate(180deg);
    }

       @media (max-width: 1280px) {
        .navbar { 
            width: 90%; 
        }
    }

    @media (max-width: 1024px) {
        .nav-links { 
            display: none !important; 
        }
        .menu-toggle { 
            display: flex; 
        }
    }

    @media (max-width: 640px) {
        .logo-image { 
            width: 210px;
            padding: 7px;
        }
    }
</style>