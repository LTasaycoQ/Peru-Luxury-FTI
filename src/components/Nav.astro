---
import "../styles/nav.css";
import { destinations } from "../data/destinations/destinatios";
import HeaderTop from "./HeaderTop.astro";
import { Image } from "astro:assets";
import logo from "../assets/logo/PLJ-LOGO-1.webp";
---

<header class="main-header">
  <HeaderTop />

  <nav class="navbar">
    <div class="navbar-container">
      <a href="/" class="logo-link">
        <Image src={logo} loading="eager" class="logo-image" alt="logo-peru-luxy" />
      </a>

      <button id="btnMenu" aria-label="Abrir menú" aria-expanded="false" class="menu-toggle">
        <i id="openMenu" class="bi bi-list"></i>
        <i id="closeMenu" class="bi bi-x-lg hidden"></i>
      </button>

      <ul class="nav-links">
        <li class="nav-item dropdown">
          <button id="btnSubmenuDesktop" class="submenu-trigger">
            <i id="iconSubmenu" class="bi bi-caret-right-fill"></i>
            <span>DESTINATIONS</span>
          </button>
          <div id="submenu" class="dropdown-content hidden">
            <ul>
              {destinations.map(d => (
                <li>
                  <a href={`/destinations/${d.distrito}`}>
                    {d.distrito.toUpperCase().replace(/-/g, " ")}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>
        <li class="nav-item"><a href="/programs">TOUR ITINERARIES</a></li>
        <li class="nav-item"><a href="/about-us">ABOUT US</a></li>
      </ul>
    </div>
  </nav>

  <div id="menuResponsive" class="mobile-menu hidden">
    <div class="mobile-item-group">
      <a href="/destinations">DESTINATIONS</a>
      <button id="btnSubMenuResponsive" aria-label="Ver destinos" aria-expanded="false">
        <i id="iconSubMenuResponsiveIcon" class="bi bi-caret-down-fill"></i>
      </button>
    </div>

    <div id="submenuResponsive" class="mobile-submenu hidden">
      <ul>
        {destinations.map(d => (
          <li>
            <a href={`/destinations/${d.distrito}`}>
              {d.distrito.charAt(0).toUpperCase() + d.distrito.slice(1).replace(/-/g, " ")}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="mobile-item">
      <a href="/programs">TOUR ITINERARIES</a>
    </div>
    <div class="mobile-item">
      <a href="/about-us">ABOUT US</a>
    </div>
  </div>
</header>


<script>
    const btnMenu = document.getElementById("btnMenu") as HTMLButtonElement;
    const openMenuIcon = document.getElementById("openMenu") as HTMLElement;
    const closeMenuIcon = document.getElementById("closeMenu") as HTMLElement;
    const menuResponsive = document.getElementById("menuResponsive") as HTMLElement;

    btnMenu.addEventListener("click", () => {
        const isHidden = menuResponsive.classList.contains("hidden");
        
        menuResponsive.classList.toggle("hidden");
        
        openMenuIcon.classList.toggle("hidden", isHidden); 
        closeMenuIcon.classList.toggle("hidden", !isHidden);
        
        btnMenu.setAttribute("aria-expanded", String(isHidden));
    });


    const btnSubmenuDesktop = document.getElementById("btnSubmenuDesktop") as HTMLButtonElement;
    const submenuDesktop    = document.getElementById("submenu") as HTMLElement;
    const iconSubmenu       = document.getElementById("iconSubmenu") as HTMLElement;

    btnSubmenuDesktop.addEventListener("click", (e) => {
        e.stopPropagation();
        const isOpen = !submenuDesktop.classList.contains("hidden");
        submenuDesktop.classList.toggle("hidden");
        iconSubmenu.style.transform = isOpen ? "rotate(0deg)" : "rotate(90deg)";
        btnSubmenuDesktop.setAttribute("aria-expanded", String(!isOpen));
    });

    document.addEventListener("click", (e) => {
        if (!btnSubmenuDesktop.contains(e.target as Node)) {
            submenuDesktop.classList.add("hidden");
            iconSubmenu.style.transform = "rotate(0deg)";
            btnSubmenuDesktop.setAttribute("aria-expanded", "false");
        }
    });

    const btnSubMenuResponsive = document.getElementById("btnSubMenuResponsive") as HTMLButtonElement;
    const submenuResponsive = document.getElementById("submenuResponsive") as HTMLElement;
    const iconSubMenuResponsiveIcon = document.getElementById("iconSubMenuResponsiveIcon") as HTMLElement;

    btnSubMenuResponsive.addEventListener("click", () => {
        const isOpen = !submenuResponsive.classList.contains("hidden");
        submenuResponsive.classList.toggle("hidden");
        iconSubMenuResponsiveIcon.style.transform = isOpen ? "rotate(0deg)" : "rotate(180deg)";
        btnSubMenuResponsive.setAttribute("aria-expanded", String(!isOpen));
    });
</script>
