---
const { fondo } = Astro.props;
---
<section class="fondo-section fade-in">
    <div class="fondo">
        <img class="hero_background" src={fondo} alt="fondo-hero">
    </div>
</section>

<style>
    
    .fade-in {
        opacity: 0.8;
        animation: fadeIn 1s forwards;
    }
    @keyframes fadeIn {
        to { opacity: 1; }
    }

    .fondo {
        width: 100%;
        height: 43em;
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
    }
    .hero_background{
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @media (width <= 830px) {
        .fondo {
            
        }
    }

    .fondo-section {
        overflow: hidden;
    }

    .fondo-section:hover .fondo {
        transform: scale(1);
    }

    @keyframes efectZoom {
        from { 
            transform: scale(1); 
        }
        to { 
            transform: scale(1.2); 
        }
    } 



</style>